Windows Registry Editor Version 5.00

; Registry Finder as TrustedInstaller
; Appears when right-clicking in empty folder space

[HKEY_CLASSES_ROOT\Directory\background\shell\RegistryFinderTI]
@="🛡️Registry Finder"
"Icon"="C:\\Program Files\\Registry Finder\\RegistryFinder.exe,0"
"Position"="Middle"
"HasLUAShield"=""

[HKEY_CLASSES_ROOT\Directory\background\shell\RegistryFinderTI\command]
@="wscript.exe \"D:\\Users\\joty79\\scripts\\RunAsTI\\RegistryFinder_TI.vbs\""
