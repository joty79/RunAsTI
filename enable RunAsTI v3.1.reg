; --- Support for .ps1 files with powershell 5 --
[HKEY_CLASSES_ROOT\Microsoft.PowerShellScript.1\shell\RunAsTI]
"MUIVerb"="Run as 🛡️"
"HasLUAShield"=""
"Icon"="powershell.exe,0"
[HKEY_CLASSES_ROOT\Microsoft.PowerShellScript.1\shell\RunAsTI\command]
@="wscript.exe \"D:\\Users\\joty79\\scripts\\RunAsTI\\RunAsTI_Menu.vbs\" \"powershell\" \"-NoExit -nop -c iex((gc -lit %L)-join[char]10)\""

; --- Support for .reg files --
