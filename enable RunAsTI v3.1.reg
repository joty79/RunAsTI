"MUIVerb"="Import as 🛡️"
"HasLUAShield"=""
"Icon"="regedit.exe,0"
[HKEY_CLASSES_ROOT\regfile\shell\RunAsTI\command]
@="wscript.exe \"D:\\Users\\joty79\\scripts\\RunAsTI\\RunAsTI_Menu.vbs\" \"regedit.exe\" \"/s\" \"%L\""

